<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Header / Back Button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp">
        <Button
            android:id="@+id/bmi_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="#1E1E1E"
            android:text="← Home"
            android:textColor="#03DAC6"
            android:textAllCaps="false"/>
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Health Tracker"
        android:textColor="#FFFFFF"
        android:textSize="32sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp"/>

    <!-- Inputs -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Weight (kg)"
        android:textColor="#888888"
        android:textSize="16sp" />
    <EditText
        android:id="@+id/bmi_input_weight"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:inputType="numberDecimal"
        android:textColor="#FFFFFF"
        android:backgroundTint="#03DAC6"
        android:textSize="24sp"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Height (cm)"
        android:textColor="#888888"
        android:textSize="16sp" />
    <EditText
        android:id="@+id/bmi_input_height"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:inputType="numberDecimal"
        android:textColor="#FFFFFF"
        android:backgroundTint="#03DAC6"
        android:textSize="24sp"
        android:layout_marginBottom="48dp"/>

    <Button
        android:id="@+id/btn_calculate_bmi"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:backgroundTint="#BB86FC"
        android:text="Calculate BMI"
        android:textColor="#000000"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="32dp"/>

    <!-- Result Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1E1E1E"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="YOUR BMI"
            android:textColor="#888888"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/tv_bmi_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0.0"
            android:textColor="#FFFFFF"
            android:textSize="56sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_bmi_category"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Waiting for input..."
            android:textColor="#03DAC6"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"/>
    </LinearLayout>

</LinearLayout>