/build

# ── Built outputs ─────────────────────────────────────────────────────────────
/build
app/build
*/build

# ── Gradle ────────────────────────────────────────────────────────────────────
.gradle
gradle-wrapper.jar
local.properties

# ── Android Studio / IntelliJ ─────────────────────────────────────────────────
.idea/
*.iml
*.iws
*.ipr
captures/
.externalNativeBuild/
.cxx/

# ── Keystore / Signing (never commit these) ───────────────────────────────────
*.jks
*.keystore
keystore.properties

# ── OS noise ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Python / Chaquopy ─────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# ── Keep lib/ folder (your .whl files) ───────────────────────────────────────
# lib/ is intentionally NOT ignored — .whl files are tracked so
# anyone who clones can build and run immediately with no extra steps.
!lib/
!lib/**